PORT=3000

# Set to true when running the BFF on the host machine (local dev).
# Containers are only reachable via Docker port-forwarding on localhost,
# not via their bridge IP. Leave unset or false in production.
SIDECAR_USE_LOCALHOST=true

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
EDITOR_BUCKET=editor-projects

# Set in Phase 2 (deploy)
CONTAINER_MANAGEMENT_URL=http://127.0.0.1:5000
